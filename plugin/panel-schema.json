{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "description": "Unique panel identifier"
    },
    "title": {
      "type": "string",
      "description": "Panel title shown in menu"
    },
    "menu": {
      "type": "object",
      "properties": {
        "location": {
          "anyOf": [
            {
              "enum": [
                "toplevel",
                "index.php",
                "edit.php",
                "upload.php",
                "link-manager.php",
                "edit.php?post_type=page",
                "edit-comments.php",
                "themes.php",
                "plugins.php",
                "users.php",
                "tools.php",
                "options-general.php"
              ]
            },
            {
              "type": "string"
            }
          ],
          "default": "options-general.php",
          "description": "Menu location: toplevel for top-level menu, or parent menu slug for submenu (default: Settings)"
        },
        "icon": {
          "type": "string",
          "description": "Dashicons class name (for toplevel only)"
        },
        "position": {
          "type": "number",
          "description": "Menu position (for toplevel only)"
        }
      }
    },
    "schema": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "const": "tab"
              },
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "capability": {
                "type": "string",
                "description": "Required capability to view this tab and its fields"
              },
              "storage": {
                "type": "string",
                "enum": [
                  "single",
                  "separate"
                ],
                "description": "Storage mode for fields in this tab"
              }
            },
            "required": [
              "type",
              "id",
              "label"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "const": "section"
              },
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "default": {
                "type": "string",
                "enum": [
                  "open",
                  "closed"
                ]
              },
              "showSave": {
                "type": "boolean",
                "description": "Show save button in section (default: true)"
              },
              "capability": {
                "type": "string",
                "description": "Required capability to view/edit fields in this section"
              }
            },
            "required": [
              "type",
              "id",
              "label"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique field identifier"
              },
              "type": {
                "const": "text"
              },
              "label": {
                "type": "string",
                "description": "Display label for the field"
              },
              "description": {
                "type": "string",
                "description": "Help text shown below the field"
              },
              "default": {
                "description": "Default value for the field"
              },
              "validate": {
                "type": "string",
                "description": "Validation rules (e.g., required|max:100)"
              },
              "sanitize": {
                "type": "string",
                "description": "Sanitization rules (e.g., trim|text_field)"
              },
              "storage": {
                "type": "string",
                "description": "Storage mode: 'single' (default), 'separate', or a registered handler name (e.g., 'sensitive')"
              },
              "placeholder": {
                "type": "string",
                "description": "Placeholder text"
              },
              "inputType": {
                "type": "string",
                "enum": [
                  "text",
                  "email",
                  "url",
                  "password"
                ],
                "default": "text",
                "description": "HTML input type"
              }
            },
            "required": [
              "id",
              "type",
              "label"
            ],
            "additionalProperties": true
          },
          {
            "type": "object",
